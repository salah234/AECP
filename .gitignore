# Secrets — never commit real values, only .env.example
.env
.env.*
.env.example

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Node / Next.js
node_modules/
.next/
out/

# Proto codegen output (regenerate via `make proto-gen`)
proto/gen/

# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# mTLS material — never commit certs/keys
*.pem
*.key
*.crt
deploy/**/certs/

# OS/editor
.DS_Store
